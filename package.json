{
  "name": "folder-batch-creator",
  "version": "1.0.0",
  "description": "跨平台文件夹批量创建工具（含Excel解析、撤销等功能）",
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "electron .",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "build": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.13.1",
    "xlsx": "^0.18.5",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "electron-builder": "^24.6.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "babel-loader": "^9.1.3",
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.5",
    "concurrently": "^8.2.2"
  }
} 