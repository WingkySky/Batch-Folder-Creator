{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Batch Folder Creator",
  "version": "2.0.0",
  "identifier": "com.foldercreator.folderbatch",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Batch Folder Creator",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/app.icns",
      "icons/icon_1024.png"
    ]
  }
}
